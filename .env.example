# ============================================================
# Family Health Tracker — Variables de Entorno
# Copiar a .env y completar con valores reales
# NUNCA commitear .env al repositorio
# ============================================================

# Supabase (público - safe para incluir en el bundle de la app)
EXPO_PUBLIC_SUPABASE_URL=https://lrjuwkkugqijahqjgcmb.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Expo (público)
EXPO_PUBLIC_PROJECT_ID=tu_expo_project_id

# ============================================================
# Supabase Edge Functions Secrets
# Configurar en: supabase secrets set NOMBRE=VALOR
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key  ← NUNCA en .env de la app
# DEEPSEEK_API_KEY=tu_deepseek_api_key_aqui
# OPENAI_API_KEY=sk-...
# INTERNAL_SECRET=genera_un_uuid_aleatorio_aqui
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=tu_twilio_auth_token_aqui
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_DEFAULT_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_SMS_FROM=+1xxxxxxxxxx
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Comandos para configurar secrets en Supabase:
#
# supabase secrets set DEEPSEEK_API_KEY=tu_deepseek_api_key_aqui
# supabase secrets set OPENAI_API_KEY=sk-...
# supabase secrets set INTERNAL_SECRET=$(uuidgen)
# supabase secrets set SUPABASE_URL=https://lrjuwkkugqijahqjgcmb.supabase.co
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
# supabase secrets set TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# supabase secrets set TWILIO_AUTH_TOKEN=tu_twilio_auth_token_aqui
# supabase secrets set TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# supabase secrets set TWILIO_DEFAULT_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# supabase secrets set TWILIO_SMS_FROM=+1xxxxxxxxxx
# supabase secrets set TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ============================================================
